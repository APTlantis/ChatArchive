{
  "name": "openai-history-archive-viewer",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "ingest": "node scripts/ingest-openai-history.js",
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:ui": "playwright test",
    "test:rust": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:CHATARCHIVE_IMPORT_SMOKE_SOURCE=(Join-Path (Get-Location) 'openai-export'); cargo test --manifest-path src-tauri/Cargo.toml\"",
    "test:native": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/qa/native-phase2.ps1",
    "test:installer": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/qa/installer-lifecycle.ps1",
    "qa:phase2": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/qa/phase2-release-gate.ps1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@mermaid-js/mermaid-zenuml": "^0.2.3",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@vitejs/plugin-react": "^6.0.3",
    "lucide-react": "^1.21.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
